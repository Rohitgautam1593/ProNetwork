<IfModule mod_rewrite.c>
    Options -Multiviews
    RewriteEngine On
    # Change this to match your install path under htdocs (keep trailing slash).
    # RewriteBase /ProNetwork/public/

    # Redirect direct external requests for .php or .html files (excluding index.php) to extension-less URLs
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s+(.*?)\.(php|html)[?\s] [NC]
    RewriteCond %{THE_REQUEST} !/index\.php [NC]
    RewriteRule ^ %1 [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]
</IfModule>
